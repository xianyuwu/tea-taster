# 岩茶品鉴评分系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值

# [必需] JWT 签名密钥 — 生产环境必须设置为一个随机字符串
# 生成方式: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 注意: 此值不能为空，且修改后所有已登录用户的 token 会失效
SECRET_KEY=

# [可选] 数据库连接 URL，默认使用本地 SQLite
# DATABASE_URL=sqlite+aiosqlite:///data/tea-taster.db
# PostgreSQL 示例: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/tea_taster

# [可选] OpenAI API Key（也可通过管理页面配置）
OPENAI_API_KEY=

# 文件存储类型: local (默认) 或 s3
STORAGE_TYPE=local

# S3 配置（仅当 STORAGE_TYPE=s3 时需要）
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=tea-taster-photos
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
# S3_PUBLIC_URL=https://cdn.example.com
